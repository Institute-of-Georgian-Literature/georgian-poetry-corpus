<TEI xmlns="http://www.tei-c.org/ns/1.0">
 
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>საქართველო იყო მათი საოცნებო სახელი</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>1939</p>
         </publicationStmt>
