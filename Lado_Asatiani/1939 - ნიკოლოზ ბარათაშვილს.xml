<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>ნიკოლოზ ბარათაშვილს</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>Publication Information</p>
         </publicationStmt>
