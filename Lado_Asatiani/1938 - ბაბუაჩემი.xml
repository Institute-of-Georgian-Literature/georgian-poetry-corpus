<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>ბაბუაჩემი</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>Publication Information</p>
         </publicationStmt>
         <sourceDesc>
            <p>https://burusi.wordpress.com/2010/04/15/lado-asatiani-16/</p>
         </sourceDesc>
      </fileDesc>
   </teiHeader>
   <text>
      <body>
         <lg xmlns="http://www.tei-c.org/ns/1.0" type="poem" met="5/5">
            
            <lg type="კატრენი" n="1" rhyme="abab">
               <l n="1" met="5/5">ის, მისი დღე და <caesura/><rhyme label="a">წუთისოფელი</rhyme>,</l>
               <l n="2" met="5/5">როცა სწყუროდა<caesura/> სულ ღვინოს <rhyme label="b">სვამდა</rhyme>,</l>
               <l n="3" met="5/5">იდგა ბუხართან <caesura/>ხელადა <rhyme label="a">სველი</rhyme></l>
               <l n="4" met="5/5">და უღვიძებდა<caesura/> ბაბუას<rhyme label="b"> მადას</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="2" rhyme="abab">
               <l n="5" met="5/5">ენამზიანი <caesura/>და ზამთრის<rhyme label="a"> გულში</rhyme></l>
               <l n="6" met="5/5">ტკბილი ქართულით<caesura/> <rhyme label="b">მოლაპარაკე</rhyme>,</l>
               <l n="7" met="5/5">ჰყვებოდა მშვიდად<caesura/> ბუხრის<rhyme label="a"> გუგუნში</rhyme></l>
               <l n="8" met="5/5">საბა-სულხანის <caesura/><rhyme label="b">იგავ-არაკებს</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="3" rhyme="abab">
               <l n="9" met="5/5">არ იშორებდა <caesura/>წელზე <rhyme label="a">სატევარს</rhyme>,</l>
               <l n="10" met="5/5">ბატონკაცური<caesura/> შვენოდა <rhyme label="b">წვერი</rhyme>,</l>
               <l n="11" met="5/5">უყვარდა ლხინში<caesura/> ღამის <rhyme label="a">გათევა</rhyme> –</l>
               <l n="12" met="5/5">მოგონებები <caesura/>ძველთაგან-<rhyme label="b">ძველი</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="4" rhyme="xaxa">
               <l n="13" met="5/5">უყვარდა მოხუცს <caesura/><rhyme label="x">ხმალამოწვდილი</rhyme></l>
               <l n="14" met="5/5">ქართველის ეშხი<caesura/> და <rhyme label="a">სილამაზე</rhyme>,</l>
               <l n="15" met="5/5">უყვარდა შვილი<caesura/> და <rhyme label="x">შვილიშვილიც</rhyme></l>
               <l n="16" met="5/5">ამღერებული <caesura/>არწივის<rhyme label="a"> ხმაზე</rhyme>.</l>
            </lg>
            
         </lg>
         
      </body>
   </text>
</TEI>