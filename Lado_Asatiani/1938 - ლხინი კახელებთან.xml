   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>ლხინი კახელებთან</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>Publication Information</p>
         </publicationStmt>
         <sourceDesc>
            <p>https://burusi.wordpress.com/2010/04/15/lado-asatiani-16/</p>
         </sourceDesc>
      </fileDesc>
