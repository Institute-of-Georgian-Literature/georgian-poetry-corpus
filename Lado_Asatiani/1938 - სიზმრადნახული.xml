         <publicationStmt>
            <p>სიზმრადნახული</p>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </publicationStmt>
         <sourceDesc>
            <p>https://poetry.ge/poets/lado-asatiani/poems/zoeex-sizmradnaxuli</p>
         </sourceDesc>
