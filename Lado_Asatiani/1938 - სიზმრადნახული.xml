   <text>
      <body>
         <lg xmlns="http://www.tei-c.org/ns/1.0" type="poem" met="5/5">
            
            <lg type="კატრენი" n="1" rhyme="abab">
               <l n="1" met="5/5">ლაჟვარდი იყო <caesura/> სუფთა და <rhyme label="a"> ღია</rhyme>,</l>
               <l n="2" met="5/5">მიმზერდა იის <caesura/> ცისფერი<rhyme label="b"> თვალი</rhyme>,</l>
               <l n="3" met="5/5">მღეროდა ვიღაც <caesura/> და <rhyme label="a">სამაიას</rhyme></l>
               <l n="4" met="5/5">ცეკვავდა სამი <caesura/> უცნობი<rhyme label="b">  ქალი</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="2" rhyme="abab">
               <l n="5" met="5/5">გადავიარე <caesura/> სინათლის <rhyme label="a">ზღვარი</rhyme></l>
               <l n="6" met="5/5">და უცნაური<caesura/>  ვნახე<rhyme label="b">  ხატება</rhyme> -</l>
               <l n="7" met="5/5">ჯერ არ მინახავს <caesura/> ქვეყნად <rhyme label="a">ამგვარი</rhyme></l>
               <l n="8" met="5/5">გასაოცარი <caesura/> <rhyme label="b"> გამოცხადება</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="3" rhyme="abab">
               <l n="9" met="5/5">სულიერივით <caesura/> დარბოდნენ <rhyme label="a">ხენი</rhyme>,</l>
               <l n="10" met="5/5">ფრინველებს ლხენით <caesura/> ვესროდი<rhyme label="b">  ისარს</rhyme>,</l>
               <l n="11" met="5/5">მოჰყავდათ ჩემსკენ <caesura/> ფასკუნჯებს <rhyme label="a">ფრენით</rhyme></l>
               <l n="12" met="5/5">პირმშვენიერი <caesura/> მნათობი <rhyme label="b"> დღისა</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="4" rhyme="abab">
               <l n="13" met="5/5">ისე ბრწყინავდა <caesura/> ვერცხლის<rhyme label="a"> ხეხილი</rhyme>,</l>
               <l n="14" met="5/5">გაოცდებოდით <caesura/> <rhyme label="b"> ფერთამხილველი</rhyme>,</l>
               <l n="15" met="5/5">ოქროს მთა-ბარი <caesura/> და<rhyme label="a"> მთაგრეხილი</rhyme>,</l>
               <l n="16" met="5/5">გამოცხადება <caesura/> <rhyme label="b"> გასაკვირველი</rhyme>!</l>
            </lg>
            
         </lg>
      </body>
   </text>
   
</TEI>