<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>*** მეც მიყვარდა გოგონა</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>Publication Information</p>
         </publicationStmt>
         <sourceDesc>
            <p>ლადო ასათიანი, "ერთტომეული", გამომცემლობა "საბჭოთა საქართველო", თბ. 1979</p>
         </sourceDesc>
      </fileDesc>
   </teiHeader>
   <text>
      <body>
         <lg xmlns="http://www.tei-c.org/ns/1.0" type="poem" met="4/3">
            
            <lg type="კატრენი" n="1" rhyme="abab">
               <l n="1" met="4/3">მეც მიყვარდა<caesura/> <rhyme label="a">გოგონა</rhyme>,</l>
               <l n="2" met="4/3">გულით იყო <caesura/> <rhyme label="b">ალალი</rhyme>,</l>
               <l n="3" met="4/3">ჭრელი გველი <caesura/><rhyme label="a">მეგონა</rhyme></l>
               <l n="4" met="4/3">მხრებზე მისი <caesura/> <rhyme label="b">დალალი</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="2" rhyme="abab">
               <l n="5" met="4/3">ტანი ჰქონდა <caesura/><rhyme label="a">ლერწამი</rhyme>,</l>
               <l n="6" met="4/3">ტროპიკებში <caesura/> <rhyme label="b">გაზრდილი</rhyme>,</l>
               <l n="7" met="4/3">მხრებზე <rhyme label="a">შენა<caesura/>ძერწავი</rhyme></l>
               <l n="8" met="4/3">ვარდისფერი <caesura/> <rhyme label="b">მანდილი</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="3" rhyme="xaxa">
               <l n="9" met="4/3">გოგო, ვარდი<caesura/> რად <rhyme label="x">გინდა</rhyme>?</l>
               <l n="10" met="4/3">როცა თვითონ<caesura/> <rhyme label="a">ვარდი ხარ</rhyme>,</l>
               <l n="11" met="4/3">ზეციური <caesura/><rhyme label="x">ვარსკვლავი</rhyme></l>
               <l n="12" met="4/3">ქვეყანაზე <caesura/><rhyme label="a">დადიხარ</rhyme>.</l>
            </lg>
            
            <lg type="ექვსტაეპედი" n="4" rhyme="xaxaxa">
               <l n="13" met="4/3">შენი თვალი <caesura/><rhyme label="x">შავია</rhyme>,</l>
               <l n="14" met="4/3">როგორც ღამე<caesura/> <rhyme label="a">ენგურის</rhyme>.</l>
               <l n="15" met="4/3">გოგო, მოდი <caesura/>და<rhyme label="x"> მითხარ</rhyme>,</l>
               <l n="16" met="4/3">გულში თუ რამ <caesura/><rhyme label="a">გეგულვის</rhyme>.</l>
               <l n="17" met="4/3">მთის ბულბული <caesura/><rhyme label="x">არა ხარ</rhyme>?</l>
               <l n="18" met="4/3">ბარში <rhyme label="a">ჩამო<caesura/>ნერგული </rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="5" rhyme="xaxa">  
               <l n="19" met="4/3">შენი ტანი <caesura/><rhyme label="x">ირხევა</rhyme>,</l>
               <l n="20" met="4/3">როგორც ღერო <caesura/><rhyme label="a">ლერწამის</rhyme>,</l>
               <l n="21" met="4/3">გოგო, მოდი, <caesura/>სად <rhyme label="x">მიხვალ</rhyme>?</l>
               <l n="22" met="4/3">გოგო, მოდი... <caesura/><rhyme label="a">ერთ წამით</rhyme>.</l>
            </lg>
            
         </lg>
      </body>
   </text>
   
</TEI>