   <text>
      <body>
         <lg xmlns="http://www.tei-c.org/ns/1.0" type="poem" met="5/4/5">
            
            <lg type="კატრენი" n="1" rhyme="abab">
               <l n="1" met="5/4/5">ვიდრე სიკვდილი <caesura/>გამახვევდეს <caesura/>ბნელ<rhyme label="a"> მოსასხამში</rhyme>,</l>
               <l n="2" met="5/4/5">ვიდრე სიკვდილის <caesura/>ჭვალი გულზე<caesura/><rhyme label="b"> დამესობოდეს</rhyme>,</l>
               <l n="3" met="5/4/5">უკანასკნელად <caesura/>დამაწვინეთ<caesura/> ჩემს ოდა <rhyme label="a">სახლში</rhyme>,</l>
               <l n="4" met="5/4/5">უკანასკნელად,<caesura/> ვიდრე თვალნი<caesura/> <rhyme label="b">დამევსებოდნენ</rhyme>.</l>
            </lg>
            
            <lg type="კატრენი" n="2" rhyme="abab">
               <l n="5" met="5/4/5">უკანასკნელად <caesura/>პაპიჩემის<caesura/> გაჯორკილ <rhyme label="a">ტახტზე</rhyme></l>
               <l n="6" met="5/4/5">დამიგეთ მაგრად, <caesura/>დამახურეთ <caesura/><rhyme label="b">შავი ნაბადი</rhyme>.</l>
               <l n="7" met="5/4/5">უკანასკნელად, <caesura/>უდრტვინველად<caesura/> მიმყოფეთ <rhyme label="a">ასე</rhyme>,</l>
               <l n="8" met="5/4/5">ვიდრე სიკვდილი <caesura/>შფოთიან სულს <caesura/><rhyme label="b">გამინაბავდეს</rhyme>.</l>
            </lg>
            
         </lg>
         
      </body>
   </text>
