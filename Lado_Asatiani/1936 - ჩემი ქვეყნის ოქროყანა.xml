<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title> ჩემი ქვეყნის ოქროყანა</title>
            <respStmt>
               <resp>TEI encoding</resp>
               <name>სალომე ლომოური</name>
            </respStmt>
            
         </titleStmt>
         <publicationStmt>
            <p>Publication Information</p>
         </publicationStmt>
         <sourceDesc>
            <p>https://poetry.ge/poets/lado-asatiani/poems/253.chemi-qveknis-oqrokanav.htm</p>
         </sourceDesc>
